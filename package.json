{
  "name": "macp-playground",
  "version": "0.2.0",
  "private": true,
  "description": "MACP Playground — file-backed showcase service for MACP demos, with scenario compilation and example-agent bootstrap.",
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/jest-e2e.config.ts",
    "test:integration": "jest --config test/jest.integration.config.ts --runInBand",
    "test:integration:docker": "INTEGRATION_CONTROL_PLANE=docker jest --config test/jest.integration.config.ts --runInBand",
    "test:integration:remote": "INTEGRATION_CONTROL_PLANE=remote jest --config test/jest.integration.config.ts --runInBand",
    "scenario": "ts-node scripts/scenario.ts",
    "scenario:validate": "ts-node scripts/scenario.ts validate",
    "scenario:dry-run": "ts-node scripts/scenario.ts dry-run",
    "scenario:new": "ts-node scripts/scenario.ts new",
    "scenario:lint": "ts-node scripts/scenario.ts lint"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.4.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "commander": "^4.1.1",
    "js-yaml": "^4.1.0",
    "macp-sdk-typescript": "^0.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.16",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.4",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
